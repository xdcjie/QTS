{
  "components": {
    "schemas": {
      "AccountSnapshotSchema": {
        "description": "Account snapshot response schema.",
        "properties": {
          "account_id": {
            "title": "Account Id",
            "type": "string"
          },
          "cash": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Cash",
            "type": "object"
          }
        },
        "required": [
          "account_id",
          "cash"
        ],
        "title": "AccountSnapshotSchema",
        "type": "object"
      },
      "BacktestRequestSchema": {
        "description": "HTTP request for submitting a backtest.",
        "properties": {
          "config_path": {
            "minLength": 1,
            "title": "Config Path",
            "type": "string"
          }
        },
        "required": [
          "config_path"
        ],
        "title": "BacktestRequestSchema",
        "type": "object"
      },
      "BacktestRunResultSchema": {
        "description": "HTTP response for a submitted research backtest run.",
        "properties": {
          "artifact_hashes": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Artifact Hashes",
            "type": "object"
          },
          "equity_curve_path": {
            "title": "Equity Curve Path",
            "type": "string"
          },
          "fills_path": {
            "title": "Fills Path",
            "type": "string"
          },
          "manifest_path": {
            "title": "Manifest Path",
            "type": "string"
          },
          "metrics": {
            "additionalProperties": true,
            "title": "Metrics",
            "type": "object"
          },
          "orders_path": {
            "title": "Orders Path",
            "type": "string"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "manifest_path",
          "equity_curve_path",
          "orders_path",
          "fills_path",
          "metrics",
          "artifact_hashes"
        ],
        "title": "BacktestRunResultSchema",
        "type": "object"
      },
      "BacktestRunSchema": {
        "description": "HTTP response for a listed backtest summary.",
        "properties": {
          "config_path": {
            "title": "Config Path",
            "type": "string"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "config_path",
          "status"
        ],
        "title": "BacktestRunSchema",
        "type": "object"
      },
      "BacktestStrategyOptionSchema": {
        "description": "HTTP response for a runnable backtest strategy option.",
        "properties": {
          "config_path": {
            "title": "Config Path",
            "type": "string"
          },
          "label": {
            "title": "Label",
            "type": "string"
          }
        },
        "required": [
          "label",
          "config_path"
        ],
        "title": "BacktestStrategyOptionSchema",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "KillSwitchCommandSchema": {
        "description": "Kill-switch mutation command.",
        "properties": {
          "reason": {
            "title": "Reason",
            "type": "string"
          },
          "scope": {
            "$ref": "#/components/schemas/KillSwitchScopeSchema"
          },
          "scope_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scope Id"
          }
        },
        "required": [
          "scope",
          "reason"
        ],
        "title": "KillSwitchCommandSchema",
        "type": "object"
      },
      "KillSwitchResponseSchema": {
        "description": "Kill-switch current state response.",
        "properties": {
          "active": {
            "title": "Active",
            "type": "boolean"
          },
          "reason": {
            "title": "Reason",
            "type": "string"
          },
          "scope": {
            "title": "Scope",
            "type": "string"
          },
          "scope_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scope Id"
          }
        },
        "required": [
          "scope",
          "scope_id",
          "active",
          "reason"
        ],
        "title": "KillSwitchResponseSchema",
        "type": "object"
      },
      "KillSwitchScopeSchema": {
        "description": "Kill-switch scoping model.",
        "enum": [
          "global",
          "account",
          "strategy",
          "instrument"
        ],
        "title": "KillSwitchScopeSchema",
        "type": "string"
      },
      "OrderStatusSchema": {
        "description": "Order status response schema.",
        "properties": {
          "order_id": {
            "title": "Order Id",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "order_id",
          "status"
        ],
        "title": "OrderStatusSchema",
        "type": "object"
      },
      "RuntimeCommandResponseSchema": {
        "description": "Payload for runtime pause/resume commands.",
        "properties": {
          "state": {
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "state"
        ],
        "title": "RuntimeCommandResponseSchema",
        "type": "object"
      },
      "RuntimeCommandResultResponseSchema": {
        "description": "Payload for auditable runtime command results.",
        "properties": {
          "command_id": {
            "title": "Command Id",
            "type": "string"
          },
          "evidence": {
            "additionalProperties": true,
            "title": "Evidence",
            "type": "object"
          },
          "failure_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Reason"
          },
          "idempotency_key": {
            "title": "Idempotency Key",
            "type": "string"
          },
          "reason_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason Code"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "command_id",
          "idempotency_key",
          "status",
          "evidence"
        ],
        "title": "RuntimeCommandResultResponseSchema",
        "type": "object"
      },
      "StrategyStatusSchema": {
        "description": "Strategy status response schema.",
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          },
          "strategy_id": {
            "title": "Strategy Id",
            "type": "string"
          }
        },
        "required": [
          "strategy_id",
          "status"
        ],
        "title": "StrategyStatusSchema",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Quant Trading System",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/accounts/{account_id}": {
      "get": {
        "description": "Perform account_snapshot.",
        "operationId": "account_snapshot_accounts__account_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "account_id",
            "required": true,
            "schema": {
              "title": "Account Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountSnapshotSchema"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Account Snapshot"
      }
    },
    "/backtests": {
      "get": {
        "description": "List recent backtest runs from persisted summaries.",
        "operationId": "list_backtests_backtests_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/BacktestRunSchema"
                  },
                  "title": "Response List Backtests Backtests Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Backtests"
      },
      "post": {
        "description": "Submit a backtest request through the backtest application service.",
        "operationId": "submit_backtest_backtests_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BacktestRequestSchema"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BacktestRunResultSchema"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit Backtest"
      }
    },
    "/backtests/strategy-options": {
      "get": {
        "description": "List runnable backtest strategy options from configured backtest files.",
        "operationId": "list_backtest_strategy_options_backtests_strategy_options_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
